PORT=5050

# ──────────────────────────────────────────
# LLM 서버 (aiServer.js)
# OS 자동 감지 — 아래 값 없어도 기본값으로 동작
# ──────────────────────────────────────────
# macOS (Apple Silicon) — MLX LM Server
# MLX_SERVER_URL=http://localhost:8080
# MLX_MODEL=mlx-community/Meta-Llama-3.1-8B-Instruct-4bit

# Linux / EC2 — Ollama
# LLM_SERVER_URL=http://localhost:11434
# LLM_MODEL=gemma3:12b

# ──────────────────────────────────────────
# 파인튜닝 데이터 생성 (generate_training_data.js)
# ──────────────────────────────────────────
# GOOGLE_API_KEY=...    # aistudio.google.com에서 발급 (무료, 하루 1,500회)
# GENERATOR_MODEL=gemini-2.0-flash   # 생략 시 기본값 사용
# DELAY_MS=500                       # 요청 간 딜레이 (기본 500ms)
