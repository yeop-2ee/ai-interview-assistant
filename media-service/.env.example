PORT=4000

# Python 실행 경로 (자동 감지: macOS=python3, Windows=python)
# Wav2Lip venv 사용 시 venv 내 Python 경로로 변경 필요
# PYTHON_PATH=/path/to/Wav2Lip/.venv/bin/python      (macOS)
# PYTHON_PATH=C:\path\to\Wav2Lip\.venv\Scripts\python.exe  (Windows)

# STT 모델 (플랫폼별 자동 분기)
# macOS  (mlx-whisper): mlx-community/whisper-large-v3-turbo
# Windows (faster-whisper): large-v3-turbo
# WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Wav2Lip (미설정 시 fallback 모드로 동작)
WAV2LIP_INFERENCE_PATH=/absolute/path/to/Wav2Lip/inference.py
WAV2LIP_CHECKPOINT_PATH=/absolute/path/to/Wav2Lip/checkpoints/wav2lip_gan.pth
WAV2LIP_SERVER_PORT=19876
