# Server
PORT=4000

# Python
# Apple Silicon: /Users/<user>/.pyenv/versions/3.9.18/bin/python3.9
# 기본값: python3
PYTHON_PATH=python3

# Whisper STT 모델 (mlx-whisper 사용)
# 기본값: mlx-community/whisper-large-v3-turbo
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Wav2Lip (로컬 모델 경로)
# 실제 Wav2Lip 저장소의 inference.py 절대 경로
WAV2LIP_INFERENCE_PATH=/absolute/path/to/Wav2Lip/inference.py
# 체크포인트(.pth) 절대 경로
WAV2LIP_CHECKPOINT_PATH=/absolute/path/to/Wav2Lip/checkpoints/wav2lip_gan.pth
# 상시 실행 서버 포트 (기본값: 19876)
WAV2LIP_SERVER_PORT=19876

# Wav2Lip 사전 영상 생성 스크립트 (scripts/generate_avatar_videos.py) 전용
# 미설정 시 ~/Desktop/Wav2Lip 사용
WAV2LIP_DIR=/absolute/path/to/Wav2Lip
